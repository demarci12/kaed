---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="hero">
		<p class="eyebrow">Early-stage venture capital</p>
		<h1>Backing the<br /><em>next thing</em> early.</h1>
		<p class="lede">
			KAED partners with founders at the very beginning — when conviction
			matters more than traction. We write first checks and stay close.
		</p>
		<div class="hero-actions">
			<a class="cta" href="#signup">Join the list</a>
			<a class="text-link" href="/login">Partner login →</a>
		</div>
	</section>

	<section class="principles">
		<div class="principle">
			<span class="num">01</span>
			<h3>First checks</h3>
			<p>We lead and co-lead pre-seed and seed rounds with high conviction.</p>
		</div>
		<div class="principle">
			<span class="num">02</span>
			<h3>Hands close</h3>
			<p>Direct access to partners — no associates between you and decisions.</p>
		</div>
		<div class="principle">
			<span class="num">03</span>
			<h3>Long horizon</h3>
			<p>We build for the decade, not the next markup. Patience is the edge.</p>
		</div>
	</section>

	<section id="signup" class="signup">
		<div class="signup-copy">
			<h2>Stay in the loop</h2>
			<p>Occasional notes on what we're funding and thinking. No noise.</p>
		</div>
		<form id="signup-form" class="signup-form">
			<label class="sr-only" for="email">Email address</label>
			<input id="email" name="email" type="email" placeholder="you@company.com" required />
			<button type="submit">Subscribe</button>
		</form>
		<div id="signup-status" class="status" aria-live="polite"></div>
	</section>
</Layout>

<script>
	const form = document.getElementById('signup-form');
	const emailInput = document.getElementById('email') as HTMLInputElement;
	const status = document.getElementById('signup-status');
	const submitButton = form?.querySelector('button[type="submit"]');

	const setStatus = (message: string, tone = 'idle') => {
		if (!status) return;
		status.textContent = message;
		status.className = `status ${tone}`;
	};

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();

		const email = emailInput?.value.trim();

		if (!email) {
			setStatus('Enter an email address first.', 'error');
			return;
		}

		setStatus('Submitting your email...', 'loading');
		if (submitButton) submitButton.setAttribute('disabled', 'true');

		try {
			const response = await fetch('/api/subscribe', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({ email }),
			});

			if (!response.ok) {
				const payload = await response.json().catch(() => null);
				throw new Error(payload?.error || 'Unable to save your signup right now.');
			}

			if (form instanceof HTMLFormElement) form.reset();
			setStatus('You are on the list. Thanks.', 'success');
		} catch (error) {
			setStatus(error instanceof Error ? error.message : 'Signup failed. Try again.', 'error');
		} finally {
			if (submitButton) submitButton.removeAttribute('disabled');
		}
	});
</script>

<style>
	.hero {
		max-width: 720px;
	}

	.eyebrow {
		margin: 0 0 20px;
		font-size: 13px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--muted);
	}

	h1 {
		margin: 0;
		font-family: var(--serif);
		font-weight: 600;
		font-size: clamp(2.6rem, 7vw, 5rem);
		line-height: 1.02;
		letter-spacing: -0.03em;
	}

	h1 em {
		font-style: italic;
	}

	.lede {
		max-width: 54ch;
		margin: 28px 0 0;
		font-size: 18px;
		line-height: 1.6;
		color: var(--muted);
	}

	.hero-actions {
		display: flex;
		align-items: center;
		gap: 24px;
		margin-top: 36px;
	}

	.cta {
		display: inline-flex;
		align-items: center;
		padding: 13px 26px;
		border-radius: 999px;
		background: var(--ink);
		color: #fff;
		font-size: 15px;
		font-weight: 500;
		text-decoration: none;
		border: 1px solid var(--ink);
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}

	.cta:hover {
		background: transparent;
		color: var(--ink);
	}

	.text-link {
		color: var(--muted);
		text-decoration: none;
		font-size: 15px;
		transition: color 0.15s ease;
	}

	.text-link:hover {
		color: var(--ink);
	}

	.principles {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 32px;
		margin-top: 96px;
		padding-top: 48px;
		border-top: 1px solid var(--line);
	}

	.principle .num {
		font-family: var(--serif);
		font-size: 14px;
		color: var(--muted);
	}

	.principle h3 {
		margin: 12px 0 8px;
		font-family: var(--serif);
		font-size: 22px;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.principle p {
		margin: 0;
		color: var(--muted);
		font-size: 15px;
		line-height: 1.6;
	}

	.signup {
		margin-top: 96px;
		padding: 40px;
		background: var(--paper);
		border: 1px solid var(--line);
		border-radius: 16px;
	}

	.signup-copy h2 {
		margin: 0;
		font-family: var(--serif);
		font-size: 28px;
		font-weight: 600;
		letter-spacing: -0.02em;
	}

	.signup-copy p {
		margin: 8px 0 0;
		color: var(--muted);
	}

	.signup-form {
		display: flex;
		gap: 10px;
		flex-wrap: wrap;
		margin-top: 24px;
	}

	input[type='email'] {
		flex: 1 1 280px;
		min-width: 220px;
		height: 48px;
		padding: 0 16px;
		font-family: var(--sans);
		font-size: 15px;
		color: var(--ink);
		background: var(--canvas);
		border: 1px solid var(--line);
		border-radius: 999px;
		outline: none;
		transition: border-color 0.15s ease;
	}

	input[type='email']:focus {
		border-color: var(--ink);
	}

	.signup-form button {
		height: 48px;
		padding: 0 28px;
		font-family: var(--sans);
		font-size: 15px;
		font-weight: 500;
		color: #fff;
		background: var(--ink);
		border: 1px solid var(--ink);
		border-radius: 999px;
		cursor: pointer;
		transition:
			background 0.15s ease,
			color 0.15s ease;
	}

	.signup-form button:hover {
		background: transparent;
		color: var(--ink);
	}

	.signup-form button:disabled {
		cursor: progress;
		opacity: 0.6;
	}

	.status {
		margin-top: 14px;
		min-height: 1.2em;
		font-size: 14px;
		color: var(--muted);
	}

	.status.error {
		color: #b4231f;
	}

	.status.success {
		color: #1f7a3d;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 720px) {
		.principles {
			grid-template-columns: 1fr;
			gap: 28px;
			margin-top: 64px;
		}
		.signup {
			margin-top: 64px;
			padding: 28px 20px;
		}
		.signup-form button,
		input[type='email'] {
			width: 100%;
			flex: 1 1 100%;
		}
	}
</style>
