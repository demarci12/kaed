import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="page">
		<section class="hero" aria-labelledby="hero-title">
			<p class="eyebrow">KAED</p>
			<h1 id="hero-title">Coming soon.</h1>
			<p class="lede">
				A white, text-first studio page with sharp black tech character energy. 
				Newsletter signups open soon.
			</p>

			<form class="signup" id="signup-form">
				<label class="sr-only" for="email">Email address</label>
				<input id="email" name="email" type="email" placeholder="Enter your email" required />
				<button type="submit">Sign up for newsletter</button>
			</form>
			<p class="status" id="signup-status" aria-live="polite"></p>
		</section>

		<section class="glyph-field" aria-hidden="true">
			<div class="glyph glyph-a">A</div>
			<div class="glyph glyph-k">K</div>
			<div class="glyph glyph-e">E</div>
			<div class="glyph glyph-d">D</div>
			<div class="glyph glyph-bracket">{ }</div>
			<div class="glyph glyph-code">&lt;/&gt;</div>
		</section>

		<footer class="footer">Creator is Marton Deak</footer>
	</main>
</Layout>

	<script>
	const form = document.getElementById('signup-form');
	const emailInput = document.getElementById('email');
	const status = document.getElementById('signup-status');
	const submitButton = form?.querySelector('button[type="submit"]');

	const setStatus = (message, tone = 'idle') => {
		if (!status) return;
		status.textContent = message;
		status.dataset.tone = tone;
	};

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();

		const email = emailInput?.value.trim();

		if (!email) {
			setStatus('Enter an email address first.', 'error');
			return;
		}

		setStatus('Submitting your email...', 'loading');
		submitButton?.setAttribute('disabled', 'true');

		try {
			const response = await fetch('/api/subscribe', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({ email }),
			});

			if (!response.ok) {
				const payload = await response.json().catch(() => null);
				throw new Error(payload?.error || 'Unable to save your signup right now.');
			}

			form.reset();
			setStatus('You are on the list. Thanks.', 'success');
		} catch (error) {
			setStatus(error instanceof Error ? error.message : 'Signup failed. Try again.', 'error');
		} finally {
			submitButton?.removeAttribute('disabled');
		}
	});
</script>

<style>
	:global(body) {
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: #ffffff;
		color: #111111;
	}

	.page {
		min-height: 100vh;
		display: grid;
		grid-template-rows: 1fr auto;
		padding: 32px;
		position: relative;
		overflow: hidden;
	}

	.hero {
		max-width: 760px;
		align-self: center;
		z-index: 1;
	}

	.eyebrow {
		margin: 0 0 18px;
		font-size: 0.82rem;
		letter-spacing: 0.45em;
		text-transform: uppercase;
		font-weight: 700;
	}

	h1 {
		margin: 0;
		font-size: clamp(4rem, 12vw, 8.5rem);
		line-height: 0.92;
		letter-spacing: -0.08em;
		font-weight: 800;
		max-width: 8ch;
	}

	.lede {
		margin: 24px 0 0;
		max-width: 40rem;
		font-size: clamp(1.05rem, 2vw, 1.35rem);
		line-height: 1.6;
		color: #2a2a2a;
	}

	.signup {
		display: flex;
		gap: 12px;
		flex-wrap: wrap;
		margin-top: 32px;
	}

	.signup input,
	.signup button {
		height: 56px;
		border-radius: 999px;
		border: 1px solid #111111;
		font: inherit;
	}

	.signup input {
		min-width: min(100%, 320px);
		padding: 0 20px;
		background: #ffffff;
		color: #111111;
	}

	.signup input::placeholder {
		color: #666666;
	}

	.signup button {
		padding: 0 24px;
		background: #111111;
		color: #ffffff;
		cursor: pointer;
		font-weight: 700;
		letter-spacing: 0.01em;
	}

	.signup button:disabled {
		cursor: progress;
		opacity: 0.7;
	}

	.status {
		margin: 14px 0 0;
		min-height: 1.4em;
		font-size: 0.95rem;
		color: #2a2a2a;
	}

	.status[data-tone='error'] {
		color: #a40000;
	}

	.status[data-tone='success'] {
		color: #0b5f2a;
	}

	.status[data-tone='loading'] {
		color: #3d3d3d;
	}

	.glyph-field {
		position: absolute;
		inset: 0;
		pointer-events: none;
		opacity: 0.14;
	}

	.glyph {
		position: absolute;
		font-size: clamp(2rem, 6vw, 5rem);
		font-weight: 900;
		color: #000000;
		font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
	}

	.glyph-a { top: 8%; right: 8%; transform: rotate(-12deg); }
	.glyph-k { top: 20%; left: 8%; transform: rotate(8deg); }
	.glyph-e { bottom: 24%; right: 18%; transform: rotate(14deg); }
	.glyph-d { bottom: 12%; left: 18%; transform: rotate(-10deg); }
	.glyph-bracket { top: 52%; right: 30%; transform: translateY(-50%) rotate(6deg); }
	.glyph-code { top: 64%; left: 12%; transform: rotate(-6deg); }

	.footer {
		z-index: 1;
		padding-bottom: 8px;
		font-size: 0.95rem;
		color: #222222;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 720px) {
		.page {
			padding: 24px;
		}

		.signup button,
		.signup input {
			width: 100%;
		}

		.footer {
			padding-top: 28px;
		}
	}
</style>
