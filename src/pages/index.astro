---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<section class="hero">
		<div class="eyebrow">Y Combinator-style coming soon</div>
		<h1>KAED is coming soon.</h1>
		<p class="lede">
			A sharply minimal launch page with the orange-and-paper feel of a YC startup.
			Sign up to get product updates before the full release.
		</p>

		<div class="highlights">
			<div>Fast newsletter signup</div>
			<div>Launch updates first</div>
			<div>Built for a focused audience</div>
		</div>
	</section>

	<section class="signup-card" aria-labelledby="signup-title">
		<h2 id="signup-title">Get on the list</h2>
		<p>
			We’ll only send useful launch notes. No noise, no filler.
		</p>

		<form id="signup-form" class="signup-form">
			<label class="sr-only" for="email">Email address</label>
			<input id="email" name="email" type="email" placeholder="Email address" required />
			<button type="submit">Subscribe</button>
		</form>
		<div id="signup-status" class="status" aria-live="polite"></div>
	</section>

	<footer class="footer">Creator is Marton Deak</footer>
</Layout>

<script>
	const form = document.getElementById('signup-form');
	const emailInput = document.getElementById('email') as HTMLInputElement;
	const status = document.getElementById('signup-status');
	const submitButton = form?.querySelector('button[type="submit"]');

	const setStatus = (message: string, tone = 'idle') => {
		if (!status) return;
		status.textContent = message;
		status.className = `status ${tone}`;
	};

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();

		const email = emailInput?.value.trim();

		if (!email) {
			setStatus('Enter an email address first.', 'error');
			return;
		}

		setStatus('Submitting your email...', 'loading');
		if (submitButton) submitButton.setAttribute('disabled', 'true');

		try {
			const response = await fetch('/api/subscribe', {
				method: 'POST',
				headers: {
					'Content-Type': 'application/json',
				},
				body: JSON.stringify({ email }),
			});

			if (!response.ok) {
				const payload = await response.json().catch(() => null);
				throw new Error(payload?.error || 'Unable to save your signup right now.');
			}

			if (form instanceof HTMLFormElement) form.reset();
			setStatus('You are on the list. Thanks.', 'success');
		} catch (error) {
			setStatus(error instanceof Error ? error.message : 'Signup failed. Try again.', 'error');
		} finally {
			if (submitButton) submitButton.removeAttribute('disabled');
		}
	});
</script>

<style>
	:global(body) {
		background: #f6f6ef;
	}

	.hero {
		max-width: 760px;
		padding: 0 0 30px;
	}

	.eyebrow {
		display: inline-block;
		margin-bottom: 10px;
		padding: 3px 8px;
		background: #ff6600;
		color: #111111;
		font-size: 9pt;
		font-weight: bold;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	h1 {
		margin: 0;
		font-family: Georgia, 'Times New Roman', serif;
		font-size: clamp(2.4rem, 7vw, 5.4rem);
		line-height: 0.95;
		letter-spacing: -0.04em;
		max-width: 10ch;
	}

	.lede {
		max-width: 58ch;
		margin: 18px 0 0;
		font-size: 13pt;
		line-height: 1.55;
	}

	.highlights {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		margin-top: 24px;
	}

	.highlights div {
		padding: 6px 10px;
		border: 1px solid #d9d3c7;
		background: rgba(255, 255, 255, 0.45);
		font-size: 9pt;
	}

	.signup-card {
		max-width: 540px;
		margin: 18px 0 0;
		padding: 18px;
		border: 1px solid #d9d3c7;
		background: rgba(255, 255, 255, 0.65);
	}

	.signup-card h2 {
		margin: 0;
		font-size: 15pt;
	}

	.signup-card p {
		margin: 8px 0 0;
		color: #5c564b;
	}

	.signup-form {
		margin: 0;
		display: flex;
		gap: 8px;
		flex-wrap: wrap;
		margin-top: 16px;
	}

	input[type="email"], button {
		font-family: Verdana, Geneva, sans-serif;
		font-size: 10pt;
		height: 36px;
		border: 1px solid #111111;
		padding: 0 12px;
	}

	input[type="email"] {
		flex: 1 1 260px;
		min-width: 220px;
		background: #ffffff;
	}

	button {
		background: #ff6600;
		color: #111111;
		font-weight: bold;
		cursor: pointer;
	}

	button:disabled {
		cursor: progress;
		opacity: 0.75;
	}

	.status {
		margin-top: 10px;
		min-height: 1.2em;
		font-size: 9pt;
	}

	.status.error {
		color: #b00000;
	}

	.status.success {
		color: #006600;
	}

	.status.loading {
		color: #6a6457;
	}

	.footer {
		margin-top: 28px;
		padding-top: 12px;
		border-top: 1px solid #d9d3c7;
		font-size: 9pt;
		color: #6b665b;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 720px) {
		.signup-card {
			padding: 16px;
		}

		button,
		input[type="email"] {
			width: 100%;
		}
	}
</style>
