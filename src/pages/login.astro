---
import Layout from '../layouts/Layout.astro';
import { createSupabaseServerClient } from '../lib/supabase';

// If already signed in, there's nothing to do here.
const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const {
	data: { user },
} = await supabase.auth.getUser();
if (user) {
	return Astro.redirect('/');
}

const error = Astro.url.searchParams.get('error');
---

<Layout>
	<section class="auth">
		<p class="eyebrow">Partner access</p>
		<h1>Log in to KAED.</h1>
		<p class="lede">Continue with a connected account to access partner resources.</p>

		{error && <p class="auth-error">{error}</p>}

		<div class="providers">
			<form method="post" action="/api/auth/signin">
				<input type="hidden" name="provider" value="google" />
				<button type="submit" class="provider">
					<svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
						<path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.92c1.7-1.57 2.68-3.88 2.68-6.62Z"/>
						<path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.26c-.8.54-1.84.86-3.04.86-2.34 0-4.32-1.58-5.03-3.7H.96v2.33A9 9 0 0 0 9 18Z"/>
						<path fill="#FBBC05" d="M3.97 10.72A5.4 5.4 0 0 1 3.68 9c0-.6.1-1.18.29-1.72V4.95H.96A9 9 0 0 0 0 9c0 1.45.35 2.83.96 4.05l3.01-2.33Z"/>
						<path fill="#EA4335" d="M9 3.58c1.32 0 2.5.45 3.44 1.35l2.58-2.58C13.46.89 11.43 0 9 0A9 9 0 0 0 .96 4.95l3.01 2.33C4.68 5.16 6.66 3.58 9 3.58Z"/>
					</svg>
					Continue with Google
				</button>
			</form>

			<form method="post" action="/api/auth/signin">
				<input type="hidden" name="provider" value="github" />
				<button type="submit" class="provider">
					<svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>
					</svg>
					Continue with GitHub
				</button>
			</form>
		</div>

		<p class="auth-foot">
			Just here for updates? <a href="/#signup">Join the newsletter →</a>
		</p>
	</section>
</Layout>

<style>
	.auth {
		max-width: 460px;
		margin: 0 auto;
	}

	.eyebrow {
		margin: 0 0 16px;
		font-size: 13px;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--muted);
	}

	h1 {
		margin: 0;
		font-family: var(--serif);
		font-weight: 600;
		font-size: clamp(2rem, 5vw, 3rem);
		line-height: 1.05;
		letter-spacing: -0.02em;
	}

	.lede {
		margin: 18px 0 0;
		color: var(--muted);
		font-size: 16px;
	}

	.auth-error {
		margin: 20px 0 0;
		padding: 12px 16px;
		border: 1px solid #e7c3c1;
		background: #fbf0ef;
		border-radius: 10px;
		color: #b4231f;
		font-size: 14px;
	}

	.providers {
		display: flex;
		flex-direction: column;
		gap: 12px;
		margin-top: 32px;
	}

	.providers form {
		margin: 0;
	}

	.provider {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		width: 100%;
		height: 52px;
		font-family: var(--sans);
		font-size: 15px;
		font-weight: 500;
		color: var(--ink);
		background: var(--paper);
		border: 1px solid var(--line);
		border-radius: 999px;
		cursor: pointer;
		transition:
			border-color 0.15s ease,
			background 0.15s ease;
	}

	.provider:hover {
		border-color: var(--ink);
		background: #fff;
	}

	.auth-foot {
		margin: 28px 0 0;
		font-size: 14px;
		color: var(--muted);
	}

	.auth-foot a {
		color: var(--ink);
		text-decoration: none;
		border-bottom: 1px solid var(--line);
	}

	.auth-foot a:hover {
		border-color: var(--ink);
	}
</style>
